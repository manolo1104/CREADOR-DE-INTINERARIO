# ── Stripe ────────────────────────────────────────────────────────────────────
# Claves en: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Webhook secret — genera con: stripe listen --forward-to localhost:3000/api/stripe-webhook
# O cópialo desde: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App ────────────────────────────────────────────────────────────────────────
# URL pública del sitio (sin barra final)
APP_URL=https://tu-dominio.com

# ── Anthropic / Claude ────────────────────────────────────────────────────────
# Clave en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Sheets ──────────────────────────────────────────────────────────────
# ID del spreadsheet (en la URL de Google Sheets)
GOOGLE_SHEETS_ID=tu-spreadsheet-id
# Email del service account (Google Cloud Console)
GOOGLE_SERVICE_ACCOUNT_EMAIL=cuenta@proyecto.iam.gserviceaccount.com
# Private key del service account (con \n escapados)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
